{
  "dependencies": {
    "express": "^5.2.1",
    "firebase-admin": "^13.10.0",
    "qrcode": "^1.5.4",
    "concurrently": "^8.0.0"
  },
  "scripts": {
    "server"        : "node server/server.js",
    "update-server" : "node server/update_server.js",
    "serve-apk"     : "node scripts/serve_apk.js",
    "start"         : "concurrently \"npm run server\" \"npm run update-server\"",
    "deploy-apk"    : "node scripts/deploy_apk.js",
    "push-update"   : "node scripts/push_update.js",
    "push-policy"   : "node scripts/push_policy.js",
    "restore"       : "node scripts/restore_devices.js",
    "adb-setup"     : "node scripts/adb_setup.js",
    "qr"            : "node generate_provisioning_qr.js && open provisioning_qr.png",
    "devices"       : "curl http://localhost:3000/devices | json_pp",
    "errors"        : "curl http://localhost:3000/device/errors | json_pp",
    "updates"       : "curl http://localhost:3000/device/update/success | json_pp",
    "release-admin" : "node scripts/release_admin.js",
    "deploy"        : "node scripts/deploy.js",
    "clear-logs"    : "curl -s -X DELETE http://localhost:3000/logs/clear | json_pp",
    "clear-devices" : "curl -s -X DELETE http://localhost:3000/devices/clear | json_pp",
    "clear-errors"  : "curl -s -X DELETE http://localhost:3000/device/errors/clear | json_pp",
    "python-serve-apk": "cd /Users/macuser/Desktop/SecureMdmPocApk && python3 -m http.server 8080 --bind 0.0.0.0",
    "hide-apps"     : "node scripts/hide_apps.js",
    "unhide-apps"   : "node scripts/unhide_apps.js",
    "app-reports"   : "curl http://localhost:3000/device/apps/report | json_pp",
    "hide-apps-all" : "node scripts/hide_apps_all.js",
    "unhide-apps-all" : "node scripts/unhide_apps_all.js"
  }
}